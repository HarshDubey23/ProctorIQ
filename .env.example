CORS_ORIGINS=["http://localhost:5173"]
EAR_THRESHOLD=0.25
HEAD_POSE_YAW_THRESHOLD=30.0
HEAD_POSE_PITCH_THRESHOLD=20.0
HEAD_POSE_ROLL_THRESHOLD=30.0
SESSION_TIMEOUT_MINUTES=60
RATE_LIMIT=60/minute
REPORT_SIGNING_SECRET=change-me-to-a-random-secret

# SQLite persistence — set to a file path for persistent storage (e.g. data/proctoriq.db)
# Leave empty to use in-memory stores (default, suitable for ephemeral dev/test)
SQLITE_PATH=

# Data collection — GitHub token for committing clips
COLLECT_GITHUB_TOKEN=
COLLECT_GITHUB_REPO=HarshDubey23/ProctorIQ
COLLECT_GITHUB_BRANCH=collected-data
